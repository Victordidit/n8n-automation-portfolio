    {
      "parameters": {
        "jsCode": "const html = $input.first().json.data;\n\n// Extract page title\nconst titleMatch = html.match(/<title>([^<]+)<\\/title>/);\nconst title = titleMatch ? titleMatch[1].trim() : \"Unknown\";\n\n// Extract pricing mentions\nconst priceMatches = [...html.matchAll(/\\$[\\d,]+(?:\\/mo|\\/month|\\/year|\\/yr)?/gi)];\nconst prices = [...new Set(priceMatches.map(m => m[0]))].slice(0, 10);\n\n// Extract key feature mentions\nconst featureKeywords = ['automation', 'workflow', 'integration', 'AI', 'free', 'enterprise', 'team', 'unlimited'];\nconst featuresFound = featureKeywords.filter(keyword => \n  html.toLowerCase().includes(keyword.toLowerCase())\n);\n\n// Extract meta description\nconst metaMatch = html.match(/<meta[^>]*name=\"description\"[^>]*content=\"([^\"]+)\"/i);\nconst metaDesc = metaMatch ? metaMatch[1] : \"\";\n\n// Get word count as proxy for content changes\nconst wordCount = html.split(/\\s+/).length;\n\nreturn [{\n  json: {\n    competitor: 'Zapier',\n    url: 'https://zapier.com/pricing',\n    pageTitle: title,\n    metaDescription: metaDesc,\n    pricesFound: prices,\n    featuresFound,\n    wordCount,\n    scrapedAt: new Date().toISOString(),\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        416,
        0
      ],
      "id": "32bfd4cf-b497-4730-922b-7fa6c7eb9d91",
      "name": "Extract Key Info"
    },
    {
      "parameters": {
        "modelId": {
          "__rl": true,
          "value": "gpt-4o-mini",
          "mode": "list",
          "cachedResultName": "GPT-4O-MINI"
        },
        "responses": {
          "values": [
            {
              "content": "=You are an expert competitive intelligence analyst.\n\nAnalyze this competitor data and provide intelligence insights.\n\nCompetitor: {{ $json.competitor }}\nURL: {{ $json.url }}\nPage Title: {{ $json.pageTitle }}\nMeta Description: {{ $json.metaDescription }}\nFeatures Found: {{ $json.featuresFound }}\nPrices Found: {{ $json.pricesFound }}\nWord Count: {{ $json.wordCount }}\nScraped At: {{ $json.scrapedAt }}\n\nBased on this data provide:\n1. Analysis of their current positioning\n2. Key features they are promoting\n3. Pricing strategy insights\n4. Competitive threats to our business\n5. Recommended actions for our team\n\nAlso determine if this requires urgent attention.\n\nRespond in this exact format:\nUrgentAlert: [Yes/No]\nChangesDetected: [summary of changes]\nPricingInfo: [pricing insights]\nAnalysis: [full competitive analysis]\nRecommendations: [specific action items]"
            }
          ]
        },
        "builtInTools": {},
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 2.1,
      "position": [
        624,
        0
      ],
      "id": "6e74296f-bb94-4a14-8f86-1bdc093d7283",
      "name": "Message a model",
      "credentials": {
        "openAiApi": {
          "id": "R9ufjb9DxGq4ix0a",
          "name": "OpenAi account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const aiOutput = $input.first().json.output?.[0]?.content?.[0]?.text || \"\";\nconst original = $('Extract Key Info').first().json;\n\nconst urgentMatch = aiOutput.match(/UrgentAlert:\\s*(.+)/);\nconst changesMatch = aiOutput.match(/ChangesDetected:\\s*(.+)/);\nconst pricingMatch = aiOutput.match(/PricingInfo:\\s*(.+)/);\nconst analysisMatch = aiOutput.match(/Analysis:\\s*([\\s\\S]+?)(?=Recommendations:)/);\nconst recommendationsMatch = aiOutput.match(/Recommendations:\\s*([\\s\\S]+)/);\n\nconst isUrgent = urgentMatch ? urgentMatch[1].trim().toLowerCase().includes('yes') : false;\n\nreturn [{\n  json: {\n    competitor: original.competitor,\n    url: original.url,\n    scrapedAt: original.scrapedAt,\n    featuresFound: original.featuresFound.join(', '),\n    wordCount: original.wordCount,\n    urgentAlert: isUrgent,\n    changesDetected: changesMatch ? changesMatch[1].trim() : \"\",\n    pricingInfo: pricingMatch ? pricingMatch[1].trim() : \"\",\n    analysis: analysisMatch ? analysisMatch[1].trim() : \"\",\n    recommendations: recommendationsMatch ? recommendationsMatch[1].trim() : \"\",\n    date: new Date().toDateString(),\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
