    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst today = new Date();\n\nconst results = [];\n\nfor (const item of items) {\n  const invoice = item.json;\n  const dueDate = new Date(invoice['Due Date']);\n  const daysOverdue = Math.floor((today - dueDate) / (1000 * 60 * 60 * 24));\n\n  let urgency;\n  let tone;\n\n  if (daysOverdue <= 0) {\n    urgency = 'Due Soon';\n    tone = 'friendly reminder';\n  } else if (daysOverdue <= 14) {\n    urgency = 'Overdue';\n    tone = 'polite but firm follow-up';\n  } else if (daysOverdue <= 30) {\n    urgency = 'Seriously Overdue';\n    tone = 'urgent and serious follow-up';\n  } else {\n    urgency = 'Critical';\n    tone = 'final notice before escalation';\n  }\n\n  results.push({\n    json: {\n      invoiceId: invoice['Invoice ID'],\n      client: invoice['Client'],\n      clientEmail: invoice['Client Email'],\n      amount: invoice['Amount'],\n      dueDate: invoice['Due Date'],\n      daysOverdue,\n      urgency,\n      tone,\n      rowNumber: invoice['row_number'],\n    }\n  });\n}\n\nreturn results;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
