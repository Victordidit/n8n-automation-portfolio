          "id": "R9ufjb9DxGq4ix0a",
          "name": "OpenAi account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const aiItems = $input.all();\nconst originalItems = $('Code in JavaScript').all();\n\nreturn aiItems.map((item, i) => {\n  const text = item.json.output?.[0]?.content?.[0]?.text || \"\";\n  const original = originalItems[i]?.json || {};\n\n  const subjectMatch = text.match(/Subject:\\s*(.+)/);\n  const bodyMatch = text.match(/Body:\\s*([\\s\\S]+)/);\n\n  return {\n    json: {\n      invoiceId: original.invoiceId,\n      client: original.client,\n      clientEmail: original.clientEmail,\n      amount: original.amount,\n      dueDate: original.dueDate,\n      daysOverdue: original.daysOverdue,\n      urgency: original.urgency,\n      rowNumber: original.rowNumber,\n      subject: subjectMatch ? subjectMatch[1].trim() : \"\",\n      body: bodyMatch ? bodyMatch[1].trim() : \"\",\n    }\n  };\n});"
      },
