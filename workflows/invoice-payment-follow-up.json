          "cachedResultName": "GPT-4O-MINI"
        },
        "responses": {
          "values": [
            {
              "content": "=You are a professional accounts receivable assistant.\n\nWrite a {{ $json.tone }} email for an unpaid invoice.\n\nInvoice Details:\n- Invoice ID: {{ $json.invoiceId }}\n- Client: {{ $json.client }}\n- Amount: {{ $json.amount }}\n- Due Date: {{ $json.dueDate }}\n- Days Overdue: {{ $json.daysOverdue }}\n- Urgency Level: {{ $json.urgency }}\n\nWrite a professional email with:\n- A subject line\n- A clear payment request\n- Payment details reminder\n- A call to action\n- Professional sign off\n\nRespond in this exact format:\nSubject: [subject]\nBody: [email body]"
            }
          ]
        },
        "builtInTools": {},
        "options": {}
      },
