    {
      "parameters": {
        "jsCode": "// Enhanced extraction without relying on Gemini API\nconst websiteData = ($node[\"Scrape Website\"].json.data || '').toString();\nconst originalData = $node[\"Clean Website\"].json;\n\n// Initialize extracted data\nlet extractedData = {\n  emails: [],\n  description: '',\n  social_media: [],\n  street: '',\n  city: '',\n  state: '',\n  country: '',\n  services: '',\n  business_hours: ''\n};\n\nif (websiteData && websiteData.length > 0) {\n  // Extract emails using regex\n  const emailRegex = /\\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Z|a-z]{2,}\\b/g;\n  const emailMatches = websiteData.match(emailRegex) || [];\n  extractedData.emails = [...new Set(emailMatches.filter(email => \n    !email.includes('example.com') && \n    !email.includes('test.com') &&\n    !email.includes('placeholder')\n  ))];\n\n  // Extract description from meta tags\n  const metaDescRegex = /<meta[^>]*name=[\"']description[\"'][^>]*content=[\"']([^\"']*)[\"'][^>]*>/i;\n  const metaDescMatch = websiteData.match(metaDescRegex);\n  if (metaDescMatch && metaDescMatch[1]) {\n    extractedData.description = metaDescMatch[1].trim();\n  }\n\n  // Try to extract title if no description\n  if (!extractedData.description) {\n    const titleRegex = /<title[^>]*>([^<]+)<\\/title>/i;\n    const titleMatch = websiteData.match(titleRegex);\n    if (titleMatch && titleMatch[1]) {\n      extractedData.description = titleMatch[1].trim();\n    }\n  }\n\n  // Extract social media links\n  const socialRegex = /(?:https?:\\/\\/)(?:www\\.)?(facebook|twitter|instagram|linkedin|youtube)\\.com\\/[^\\s\"'<>]+/gi;\n  const socialMatches = websiteData.match(socialRegex) || [];\n  extractedData.social_media = [...new Set(socialMatches)];\n\n  // Extract phone numbers\n  const phoneRegex = /(?:\\+\\d{1,3}[-\\s]?)?(?:\\(?\\d{3}\\)?[-\\s]?)?\\d{3}[-\\s]?\\d{4}/g;\n  const phoneMatches = websiteData.match(phoneRegex) || [];\n  const validPhones = phoneMatches.filter(phone => phone.length >= 10);\n\n  // Extract address information from common patterns\n  const addressRegex = /(?:address|location|visit us)[^\\n]*([^\\n]{20,100})/gi;\n  const addressMatches = websiteData.match(addressRegex) || [];\n  if (addressMatches.length > 0) {\n    const addressText = addressMatches[0].replace(/address|location|visit us/gi, '').trim();\n    const parts = addressText.split(/[,\\n]/);\n    if (parts.length > 0) extractedData.street = parts[0]?.trim() || '';\n    if (parts.length > 1) extractedData.city = parts[1]?.trim() || '';\n    if (parts.length > 2) extractedData.state = parts[2]?.trim() || '';\n  }\n\n  // Extract business hours\n  const hoursRegex = /(?:hours|open|timing)[^\\n]*([^\\n]{10,80})/gi;\n  const hoursMatches = websiteData.match(hoursRegex) || [];\n  if (hoursMatches.length > 0) {\n    extractedData.business_hours = hoursMatches[0].replace(/hours|open|timing/gi, '').trim();\n  }\n\n  // Extract services\n  const servicesRegex = /(?:services|we offer|specializing)[^\\n]*([^\\n]{20,150})/gi;\n  const serviceMatches = websiteData.match(servicesRegex) || [];\n  if (serviceMatches.length > 0) {\n    extractedData.services = serviceMatches[0].replace(/services|we offer|specializing/gi, '').trim();\n  }\n}\n\n// Merge with original data\nconst finalData = {\n  business_name: originalData.business_name || '',\n  business_type: originalData.business_type || '',\n  title: originalData.title || '',\n  description: extractedData.description || originalData.description || '',\n  street: extractedData.street || originalData.street || '',\n  city: extractedData.city || originalData.city || '',\n  state: extractedData.state || originalData.state || '',\n  country: extractedData.country || originalData.country || '',\n  phone: originalData.phone || '',\n  website: originalData.website || '',\n  email: extractedData.emails.join(', ') || '',\n  rating: originalData.rating || '',\n  social_media: extractedData.social_media.join(', ') || '',\n  search_query: originalData.search_query || '',\n  date_scraped: originalData.date_scraped || new Date().toISOString().split('T')[0],\n  services: extractedData.services || '',\n  business_hours: extractedData.business_hours || originalData.hours || '',\n  price_range: originalData.price_range || '',\n  reviews: originalData.reviews || 0,\n  data_source: 'ENHANCED_REGEX_EXTRACTED'\n};\n\nreturn { json: finalData };"
      },
