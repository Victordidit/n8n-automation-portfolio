    {
      "parameters": {
        "jsCode": "// Process Google Maps results\nconst results = [];\nconst places = $input.first().json.local_results || [];\n\nfor (const place of places) {\n  // Parse address\n  const address = place.address || '';\n  const addressParts = address.split(', ');\n  \n  // Handle service_options properly - it's an object, not array\n  let serviceOptions = '';\n  if (place.service_options && typeof place.service_options === 'object') {\n    serviceOptions = Object.keys(place.service_options)\n      .filter(key => place.service_options[key])\n      .join(', ');\n  }\n  \n  results.push({\n    business_name: place.title || '',\n    business_type: place.type || '',\n    title: place.type || '',\n    description: place.user_review || place.snippet || place.editorial_summary || '',\n    full_address: address,\n    street: addressParts[0] || '',\n    city: addressParts[1] || '',\n    state: addressParts[2] || '',\n    country: addressParts[addressParts.length - 1] || '',\n    phone: place.phone || '',\n    website: place.website || '',\n    email: '',\n    rating: place.rating || '',\n    social_media: '',\n    search_query: 'dentist near dwarka new delhi',\n    date_scraped: new Date().toISOString().split('T')[0],\n    price_range: place.price || '',\n    service_options: serviceOptions,\n    hours: place.hours || '',\n    reviews: place.reviews || 0\n  });\n}\n\nreturn results.map(item => ({ json: item }));"
      },
