    {
      "parameters": {
        "jsCode": "const raw = $json.website || '';\nconst s = raw.toString().trim();\n\n// remove trailing slashes and leading protocol\nlet cleaned = s.replace(/^https?:\\/\\//i, '').replace(/\\/+$/,'').trim();\n\n// remove accidental spaces\ncleaned = cleaned.replace(/\\s+/g,'');\n\n// if after cleaning nothing remains, return empty\nif (!cleaned) {\n  return [{ json: { ...$json, cleaned_website: '' } }];\n}\n\n// if contains invalid characters (no dot) treat as empty\nif (!/\\./.test(cleaned)) {\n  return [{ json: { ...$json, cleaned_website: '' } }];\n}\n\n// final canonical https:// + cleaned\nreturn [{ json: { ...$json, cleaned_website: 'https://' + cleaned } }];"
      },
