    {
      "parameters": {
        "jsCode": "const aiOutput = $input.first().json.output?.[0]?.content?.[0]?.text || \"\";\nconst original = $('Code in JavaScript').first().json;\n\nconst confidenceMatch = aiOutput.match(/Confidence:\\s*(.+)/);\nconst replyMatch = aiOutput.match(/Reply:\\s*([\\s\\S]+)/);\n\nreturn [{\n  json: {\n    ticketId: original.ticketId,\n    customerEmail: original.customerEmail,\n    issue: original.issue,\n    confidence: confidenceMatch ? confidenceMatch[1].trim() : \"Low\",\n    reply: replyMatch ? replyMatch[1].trim() : \"\",\n    status: 'Resolved',\n  }\n}];"
      },
