    {
      "parameters": {
        "jsCode": "const knowledgeBase = $input.all();\nconst webhook = $('Webhook').first().json.body;\n\nconst customerEmail = webhook.email;\nconst issue = webhook.issue;\nconst ticketId = 'TKT-' + Date.now();\n\n// Try to find a matching solution\nlet matchedSolution = null;\nlet matchedTopic = null;\n\nfor (const item of knowledgeBase) {\n  const topic = item.json['Topic'].toLowerCase();\n  if (issue.toLowerCase().includes(topic.toLowerCase())) {\n    matchedSolution = item.json['Solution'];\n    matchedTopic = item.json['Topic'];\n    break;\n  }\n}\n\nreturn [{\n  json: {\n    ticketId,\n    customerEmail,\n    issue,\n    matchedTopic,\n    matchedSolution,\n    hasMatch: matchedSolution !== null,\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
