    {
      "parameters": {
        "jsCode": "const html = $input.first().json.data;\n\nconst nameMatches = [...html.matchAll(/class=\"product_pod\"[\\s\\S]*?title=\"([^\"]+)\"/g)];\nconst priceMatches = [...html.matchAll(/price_color\">\\s*([^<]+)<\\/p>/g)];\nconst ratingMatches = [...html.matchAll(/star-rating (\\w+)/g)];\n\nconst results = nameMatches.map((match, i) => ({\n  name: match[1] || null,\n  price: priceMatches[i] ? priceMatches[i][1].trim() : null,\n  rating: ratingMatches[i] ? ratingMatches[i][1] : null,\n}));\n\nreturn results.map(item => ({ json: item }));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
