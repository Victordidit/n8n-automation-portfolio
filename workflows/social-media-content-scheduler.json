      "parameters": {
        "jsCode": "const items = $input.all();\n\nconst results = [];\n\nfor (const item of items) {\n  const post = item.json;\n\n  const platformGuidelines = {\n    LinkedIn: 'professional, insightful and detailed. Use 3-5 hashtags. Max 1300 characters.',\n    Twitter: 'short, punchy and engaging. Use 2-3 hashtags. Max 280 characters.',\n    Instagram: 'visual, fun and inspiring. Use 5-10 hashtags. Max 500 characters.',\n  };\n\n  const guidelines = platformGuidelines[post.Platform] || 'engaging and professional';\n\n  results.push({\n    json: {\n      postId: post['Post ID'],\n      topic: post['Topic'],\n      platform: post['Platform'],\n      scheduledDate: post['Scheduled Date'],\n      guidelines,\n      rowNumber: post['row_number'],\n    }\n  });\n}\n\nreturn results;"
      },
