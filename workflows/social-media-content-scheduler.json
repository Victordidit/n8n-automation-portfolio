    {
      "parameters": {
        "jsCode": "const aiItems = $input.all();\nconst originalItems = $('Code in JavaScript').all();\n\nreturn aiItems.map((item, i) => {\n  const text = item.json.output?.[0]?.content?.[0]?.text || \"\";\n  const original = originalItems[i]?.json || {};\n\n  const captionMatch = text.match(/Caption:\\s*([\\s\\S]+?)(?=Hashtags:)/);\n  const hashtagsMatch = text.match(/Hashtags:\\s*([\\s\\S]+)/);\n\n  return {\n    json: {\n      postId: original.postId,\n      topic: original.topic,\n      platform: original.platform,\n      scheduledDate: original.scheduledDate,\n      rowNumber: original.rowNumber,\n      caption: captionMatch ? captionMatch[1].trim() : \"\",\n      hashtags: hashtagsMatch ? hashtagsMatch[1].trim() : \"\",\n      fullPost: `${captionMatch ? captionMatch[1].trim() : \"\"}\\n\\n${hashtagsMatch ? hashtagsMatch[1].trim() : \"\"}`,\n    }\n  };\n});"
      },
