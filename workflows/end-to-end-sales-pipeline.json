        "responses": {
          "values": [
            {
              "content": "=You are an expert sales qualification assistant.\n\nScore this lead from 1-100 and determine if they are \na hot or cold lead based on their details.\n\nLead Details:\nName: {{ $('On form submission').first().json.Name }}\nCompany: {{ $('On form submission').first().json.Company }}\nIndustry: {{ $('On form submission').first().json.Industry }}\nBudget: {{ $('On form submission').first().json.Budget }}\nMessage: {{ $('On form submission').first().json.Message }}\n\nScoring criteria:\n- Budget over $5000: +40 points\n- Budget $1000-$5000: +20 points\n- Budget under $1000: +5 points\n- Enterprise/Tech industry: +30 points\n- Clear use case in message: +30 points\n\nRespond in this exact format:\nScore: [number]\nCategory: [Hot/Cold]\nReasoning: [one sentence explanation]"
            }
          ]
        },
        "builtInTools": {},
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 2.1,
