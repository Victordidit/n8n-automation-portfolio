    {
      "parameters": {
        "jsCode": "const aiOutput = $input.first().json.output?.[0]?.content?.[0]?.text || \"\";\nconst formData = $('On form submission').first().json;\n\nconst scoreMatch = aiOutput.match(/Score:\\s*(\\d+)/);\nconst categoryMatch = aiOutput.match(/Category:\\s*(.+)/);\nconst reasoningMatch = aiOutput.match(/Reasoning:\\s*(.+)/);\n\nconst score = scoreMatch ? parseInt(scoreMatch[1]) : 0;\nconst category = categoryMatch ? categoryMatch[1].trim() : \"Cold\";\nconst reasoning = reasoningMatch ? reasoningMatch[1].trim() : \"\";\n\nconst leadId = 'LEAD-' + Date.now();\n\nreturn [{\n  json: {\n    leadId,\n    name: formData.Name,\n    email: formData.Email,\n    company: formData.Company,\n    industry: formData.Industry,\n    budget: formData.Budget,\n    message: formData.Message,\n    score,\n    category,\n    reasoning,\n    isHot: category === 'Hot',\n  }\n}];"
      },
