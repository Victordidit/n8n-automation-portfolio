    {
      "parameters": {
        "jsCode": "const inventoryItems = $input.all();\nconst order = $('Code in JavaScript').first().json;\n\n// Find the matching product in inventory\nconst match = inventoryItems.find(\n  item => item.json.Product.toLowerCase() === order.product.toLowerCase()\n);\n\nconst currentStock = match ? match.json.Stock : 0;\nconst newStock = currentStock - order.quantity;\nconst rowNumber = match ? match.json.row_number : null;\nconst isLowStock = newStock <= 2;\nconst isOutOfStock = newStock <= 0;\n\nreturn [{\n  json: {\n    orderId: order.orderId,\n    product: order.product,\n    quantity: order.quantity,\n    customerEmail: order.customerEmail,\n    orderSummary: order.orderSummary,\n    currentStock,\n    newStock,\n    rowNumber,\n    stockStatus: isOutOfStock ? \"Out of Stock\" : isLowStock ? \"Low Stock\" : \"In Stock\",\n    warehouseAlert: isLowStock ? `⚠️ LOW STOCK ALERT: ${order.product} has only ${newStock} units remaining!` : null,\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
