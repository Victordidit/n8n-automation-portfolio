      "parameters": {
        "jsCode": "const orders = $input.all();\n\nreturn orders.map(order => {\n  const orderId = order.json[' Order ID '];\n  const product = order.json['Products'];\n  const quantity = order.json['Quantity'];\n  const customerEmail = order.json['Customer Email'];\n  const rowNumber = order.json['row_number'];\n\n  return {\n    json: {\n      orderId,\n      product,\n      quantity,\n      customerEmail,\n      rowNumber,\n      orderSummary: `Order #${orderId} - ${quantity}x ${product} from ${customerEmail}`,\n    }\n  };\n});"
      },
