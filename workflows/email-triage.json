    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.map(item => {\n  const text = item.json.output?.[0]?.content?.[0]?.text || \"\";\n\n  const categoryMatch = text.match(/Category:\\s*(.+)/);\n  const priorityMatch = text.match(/Priority:\\s*(.+)/);\n  const replyMatch = text.match(/Reply:\\s*([\\s\\S]+)/);\n\n  return {\n    json: {\n      from: $('Gmail Trigger').first().json.From,\n      subject: $('Gmail Trigger').first().json.Subject,\n      threadId: $('Gmail Trigger').first().json.threadId,\n      category: categoryMatch ? categoryMatch[1].trim() : \"\",\n      priority: priorityMatch ? priorityMatch[1].trim() : \"\",\n      reply: replyMatch ? replyMatch[1].trim() : \"\",\n    }\n  };\n});"
      },
